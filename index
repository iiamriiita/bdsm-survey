// ─── VOICE INPUT ──────────────────────────────────────────────────────────────
function startVoice(id, type){
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if(!SR){ showToast(T('micErr'), 4000); return; }
  if(!window.isSecureContext){ showToast(T('micErr'), 4000); return; }

  if(activeRecognition){ try{ activeRecognition.stop(); }catch(e){} activeRecognition=null; }

  const recognition = new SR();
  recognition.lang = lang==='zh' ? 'zh-TW' : 'en-US';
  recognition.interimResults = false;
  recognition.maxAlternatives = 1;
  activeRecognition = recognition;

  const statusEl = document.getElementById('micst_'+id);
  const micBtn = document.querySelector(`[onclick="startVoice('${id}','${type}')"]`);
  if(micBtn) micBtn.classList.add('recording');
  if(statusEl){ statusEl.textContent=T('micStart'); statusEl.className='mic-status active'; }

  recognition.onresult = (e) => {
    const tx = e.results[0][0].transcript;
    if(type==='open'){
      const qi = parseInt(id.replace('open_',''));
      const tas = document.querySelectorAll('.open-ta');
      if(tas[qi]){ tas[qi].value += (tas[qi].value?' ':'')+tx; openAnswers[qi]=tas[qi].value; openTranslations[qi]=''; }
    } else {
      const ta = document.querySelector(`#note_${id} textarea`);
      if(ta){ ta.value += (ta.value?' ':'')+tx; notes[id]=ta.value; noteTranslations[id]=''; }
    }
  };
  recognition.onend = () => {
    if(micBtn) micBtn.classList.remove('recording');
    if(statusEl){ statusEl.textContent=T('micStop'); statusEl.className='mic-status'; setTimeout(()=>{ if(statusEl) statusEl.textContent=''; },2000); }
    activeRecognition=null;
  };
  recognition.onerror = (e) => {
    if(micBtn) micBtn.classList.remove('recording');
    if(statusEl){ statusEl.textContent=''; statusEl.className='mic-status'; }
    if(e.error==='not-allowed'){ showToast(T('micDenied'),3000); }
    else { showToast(T('micErr'),4000); }
    activeRecognition=null;
  };

  try { recognition.start(); }
  catch(e){ showToast(T('micErr'),4000); }
}

// ─── TRANSLATION ─────────────────────────────────────────────────────────────
async function translateOne(text, langPair){
  const url = `https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=${langPair}`;
  const resp = await fetch(url);
  if(!resp.ok) throw new Error('HTTP '+resp.status);
  const data = await resp.json();
  if(data.responseStatus === 200 && data.responseData?.translatedText){
    let result = data.responseData.translatedText;
    if(result === result.toUpperCase() && text !== text.toUpperCase()) result = result.charAt(0).toUpperCase()+result.slice(1).toLowerCase();
    return result;
  }
  throw new Error(data.responseDetails || 'Translation failed');
}

async function runTranslation(){
  const btn=document.getElementById('trBtn');
  const status=document.getElementById('trStatus');
  btn.disabled=true; btn.textContent=T('trLoading');

  const langPair = lang==='zh' ? 'en|zh-TW' : 'zh-TW|en';
  const jobs=[];

  SECTIONS.forEach(sec=>{
    sec.questions.forEach((_,qi)=>{
      const id=`${sec.id}_${qi}`;
      if(notes[id]&&notes[id].trim()&&!noteTranslations[id]){
        jobs.push({type:'note',id,text:notes[id]});
      }
    });
  });
  OPEN_SEC.questions.forEach((_,qi)=>{
    if(openAnswers[qi]&&openAnswers[qi].trim()&&!openTranslations[qi]){
      jobs.push({type:'open',qi,text:openAnswers[qi]});
    }
  });

  if(!jobs.length){
    status.textContent=T('trDone');
    btn.disabled=false; btn.textContent=T('trBtn');
    buildResults();
    return;
  }

  let done=0;
  let failed=0;
  status.textContent=`${T('trLoading')} (0/${jobs.length})`;

  for(const job of jobs){
    try {
      const result = await translateOne(job.text, langPair);
      if(job.type==='note') noteTranslations[job.id]=result;
      else openTranslations[job.qi]=result;
      done++;
    } catch(e){
      failed++;
    }
    status.textContent=`${T('trLoading')} (${done+failed}/${jobs.length})`;
  }

  if(failed>0){
    status.textContent=T('trDone')+` (${failed} ${lang==='zh'?'則失敗':'failed'})`;
  } else {
    status.textContent=T('trDone');
  }
  buildResults();
  btn.disabled=false; btn.textContent=T('trBtn');
}

