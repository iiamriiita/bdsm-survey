    hasOpen=true;
    const item=document.createElement('div'); item.className='res-item';
    item.style.cssText='flex-direction:column;align-items:flex-start';
    item.innerHTML=`
      <div class="res-qtext" style="margin-bottom:5px">${TQ(q)}</div>
      <div class="open-ans">${openAnswers[qi]}</div>
      ${openTranslations[qi]?`<div class="open-ans-tr">↳ ${openTranslations[qi]}</div>`:''}`;
    oblk.appendChild(item);
  });
  if(hasOpen){
    oblk.insertAdjacentHTML('afterbegin',`<div class="res-sec-title">${TQ(OPEN_SEC)}</div>`);
    cont.appendChild(oblk);
  }
}

// ─── SHARE ────────────────────────────────────────────────────────────────────
function shareResults(){
  const state={ratings,notes,commAnswers,openAnswers,lang};
  const json=JSON.stringify(state);
  const encoded=btoa(encodeURIComponent(json));
  const url=`${location.origin}${location.pathname}?share=${encoded}`;
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(url).then(()=>showToast(T('shareOk'))).catch(()=>fallbackShare(url));
  } else { fallbackShare(url); }
}

function fallbackShare(url){
  const ta=document.createElement('textarea');
  ta.value=url; ta.style.position='fixed'; ta.style.opacity='0';
  document.body.appendChild(ta); ta.select();
  try{ document.execCommand('copy'); showToast(T('shareOk')); }
  catch(e){ showToast(T('shareNo'),4000); }
  document.body.removeChild(ta);
}

function loadShared(){
  const params=new URLSearchParams(location.search);
  const share=params.get('share');
  if(!share) return false;
  try{
    const json=decodeURIComponent(atob(share));
    const state=JSON.parse(json);
    ratings=state.ratings||{};
    notes=state.notes||{};
    commAnswers=state.commAnswers||{};
    openAnswers=state.openAnswers||{};
    if(state.lang) lang=state.lang;
    return true;
  } catch(e){ return false; }
}

// ─── MISC ────────────────────────────────────────────────────────────────────
function clearAll(){
  if(!confirm(T('confirmClear'))) return;
  ratings={}; notes={}; commAnswers={}; openAnswers={};
  noteTranslations={}; openTranslations={};
  buildSurvey();
}

function exportText(){
  let text=(lang==='zh'?'BDSM 遠距偏好調查結果':'BDSM Long-Distance Preferences – Results')+'\n\n';
  SECTIONS.forEach(sec=>{
    let items=sec.questions.map((q,qi)=>({q,id:`${sec.id}_${qi}`,score:ratings[`${sec.id}_${qi}`]||0})).filter(x=>x.score>0);
    if(sortMode==='high') items=[...items].sort((a,b)=>b.score-a.score);
    else if(sortMode==='low') items=[...items].sort((a,b)=>a.score-b.score);
    if(!items.length) return;
    text+=`=== ${TQ(sec)} ===\n`;
    items.forEach(({q,id,score})=>{
      text+=`[${score}/10] ${TQ(q)}`;
      if(notes[id]) text+=`\n  Note: ${notes[id]}`;
      if(noteTranslations[id]) text+=`\n  (${noteTranslations[id]})`;
      text+='\n';
    });
    text+='\n';
  });
  if(navigator.clipboard && window.isSecureContext){
    navigator.clipboard.writeText(text).then(()=>showToast(T('copied')));
  } else {
    const ta=document.createElement('textarea');
    ta.value=text; ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select();
    try{ document.execCommand('copy'); showToast(T('copied')); } catch(e){}
    document.body.removeChild(ta);
  }
}

let toastTimer=null;
function showToast(msg, dur=2200){
  const el=document.getElementById('toast');
  el.textContent=msg; el.classList.add('show');
  if(toastTimer) clearTimeout(toastTimer);
  toastTimer=setTimeout(()=>el.classList.remove('show'), dur);
}

// ─── INIT ────────────────────────────────────────────────────────────────────
(function init(){
  const isShared = loadShared();
  totalQ = SECTIONS.reduce((a,s)=>a+s.questions.length,0);

  if(isShared){
    // show results directly
    document.getElementById('vSurvey').style.display='none';
    document.getElementById('fixedBar').style.display='none';
    document.getElementById('vResults').style.display='block';

    // sync lang buttons
    ['btnEn','rBtnEn'].forEach(id=>{ const el=document.getElementById(id); if(el) el.classList.toggle('active',lang==='en'); });
    ['btnZh','rBtnZh'].forEach(id=>{ const el=document.getElementById(id); if(el) el.classList.toggle('active',lang==='zh'); });

    document.getElementById('rTitle').textContent=T('resTitle');
    document.getElementById('rBack').textContent=T('back');
    document.getElementById('rExport').textContent=T('export');

    // shared banner
    const banner=document.getElementById('sharedBanner');
    banner.style.display='flex';
    banner.innerHTML=`<i class="ti ti-share" aria-hidden="true"></i>${T('sharedView')}`;

    // hide edit / export on shared view
    document.getElementById('exportRow').style.display='none';

    // translate bar still visible so viewer can translate notes
    updateTranslateBar();
    updateSortLabel();
    buildResults();
    isSharedView=true;
  } else {
    buildSurvey();
    document.getElementById('rBack').textContent=T('back');
    document.getElementById('rExport').textContent=T('export');
    updateSortLabel();
    updateTranslateBar();
  }
})();
</script>
